    try.
      data(ro_runtime) = zcl_calculating_mfg_operations=>create_by_production_version( im_product = 'ZSF00001' im_plant = '7002' im_version = 'A001' ).
      data(lv_days)    = ro_runtime->aggregate_standard_capacitiy( ).
      cl_abap_unit_assert=>assert_equals( act = lv_days exp = 4 ).
    catch zcx_no_data.
    endtry.
  endmethod.

